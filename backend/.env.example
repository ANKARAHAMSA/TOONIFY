# Environment Configuration
# Copy this to .env and fill in your values

# Path to local model weights directory (after downloading from HuggingFace)
# Can also be a HF repo ID like "nitrosocke/mo-di-diffusion"
MODEL_PATH=./mo-di-diffusion

# Set to "true" to run without loading any model (uses PIL filters as mock output)
# Perfect for frontend development without a GPU
MOCK_MODE=false
