# Environment Configuration
# Copy this to .env and fill in your values

# Path to local model weights directory (after downloading from HuggingFace)
# Can also be a HF repo ID like "nitrosocke/mo-di-diffusion"
MODEL_PATH=./mo-di-diffusion

# Set to "true" to run without loading any model (uses PIL filters as mock output)
# Perfect for frontend development without a GPU
MOCK_MODE=false

# IP-Adapter Face Consistency (Milestone 2)
# Set to "true" to load IP-Adapter face model for identity preservation
USE_IP_ADAPTER=false

# IP-Adapter scale (0.0 to 1.0) — strength of face identity lock
# 0.4 = artistic freedom, 0.7 = balanced, 0.9 = strict face lock
IP_ADAPTER_SCALE=0.7
