    "# ============================================================\n",
    "# CELL 4 — Validate Dataset Before Training\n",
    "# ============================================================\n",
    "import os, json\n",
    "from PIL import Image\n",
    "\n",
    "print('Validating dataset...')\n",
    "\n",
    "# ── Load metadata ─────────────────────────────────────────\n",
    "meta_path = f'{IMAGES_DIR}/metadata.jsonl'\n",
    "if not os.path.exists(meta_path):\n",
    "    raise FileNotFoundError(f'❌ metadata.jsonl not found at {meta_path}. Run Cell 3 first.')\n",
    "\n",
    "entries = []\n",
    "with open(meta_path) as f:\n",
    "    for line_no, line in enumerate(f, 1):\n",
    "        line = line.strip()\n",
    "        if not line:\n",
    "            continue\n",
    "        try:\n",
    "            entry = json.loads(line)\n",
    "        except json.JSONDecodeError as e:\n",
    "            raise ValueError(f'❌ Invalid JSON on line {line_no}: {e}')\n",
    "        if 'file_name' not in entry or 'text' not in entry:\n",
    "            raise ValueError(f'❌ Entry on line {line_no} missing file_name or text: {entry}')\n",
    "        entries.append(entry)\n",
    "\n",
    "print(f'✅ metadata.jsonl has {len(entries)} entries')\n",
    "\n",
    "# ── Validate each image ────────────────────────────────────\n",
    "errors = []\n",
    "for entry in entries:\n",
    "    fpath = f'{IMAGES_DIR}/{entry[\"file_name\"]}'\n",
    "    if not os.path.exists(fpath):\n",
    "        errors.append(f'  Missing file: {fpath}')\n",
    "        continue\n",
    "    if os.path.getsize(fpath) < 1000:  # <1KB = corrupt/placeholder\n",
    "        errors.append(f'  Suspiciously small file ({os.path.getsize(fpath)}B): {fpath}')\n",
    "        continue\n",
    "    try:\n",
    "        img = Image.open(fpath)\n",
    "        img.verify()\n",
    "    except Exception as e:\n",
    "        errors.append(f'  Corrupt image {fpath}: {e}')\n",
    "\n",
    "if errors:\n",
    "    print('\\n❌ Dataset validation errors:')\n",
    "    for e in errors:\n",
    "        print(e)\n",
    "    raise RuntimeError('Fix the above errors before training. Re-run Cell 3 to regenerate missing images.')\n",
    "\n",
    "# ── Trigger word check ─────────────────────────────────────\n",
    "TRIGGER = 'arcane_toonify style'\n",
    "missing_trigger = [e['file_name'] for e in entries if TRIGGER not in e['text']]\n",
    "if missing_trigger:\n",
    "    print(f'\\n⚠️  {len(missing_trigger)} captions missing trigger word \"{TRIGGER}\":')\n",
    "    for f in missing_trigger:\n",
    "        print(f'   {f}')\n",
    "    print('   LoRA will still train but trigger word injection will be weaker.')\n",
    "\n",
    "print(f'\\n✅ All {len(entries)} images validated — dataset ready for training!')\n",
    "print('\\n🏁 Cell 4 complete.')\n"
   ]
  },
