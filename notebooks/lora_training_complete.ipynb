    "# ============================================================\n",
    "# CELL 1 — Install Dependencies (pinned versions, resume-safe)\n",
    "# ============================================================\n",
    "import subprocess, sys\n",
    "\n",
    "PACKAGES = [\n",
    "    'diffusers==0.27.2',\n",
    "    'transformers==4.40.2',\n",
    "    'accelerate==0.30.0',\n",
    "    'peft==0.10.0',\n",
    "    'safetensors==0.4.3',\n",
    "    'datasets==2.19.0',\n",
    "    'huggingface_hub==0.23.2',\n",
    "    'bitsandbytes==0.43.1',\n",
    "    'xformers',\n",
    "    'torchvision',\n",
    "    'Pillow',\n",
    "]\n",
    "\n",
    "print('Installing packages... (this takes 3–5 minutes on first run)')\n",
    "result = subprocess.run(\n",
    "    [sys.executable, '-m', 'pip', 'install', '-q', '--upgrade'] + PACKAGES,\n",
    "    capture_output=True, text=True\n",
    ")\n",
    "if result.returncode != 0:\n",
    "    print('⚠️  pip stderr:', result.stderr[-2000:])\n",
    "    raise RuntimeError('pip install failed — check errors above')\n",
    "\n",
    "# ── Verify critical imports ────────────────────────────────\n",
    "import importlib\n",
    "REQUIRED = ['diffusers', 'transformers', 'accelerate', 'peft', 'safetensors']\n",
    "for pkg in REQUIRED:\n",
    "    try:\n",
    "        m = importlib.import_module(pkg)\n",
    "        v = getattr(m, '__version__', '?')\n",
    "        print(f'  ✅ {pkg}=={v}')\n",
    "    except ImportError as e:\n",
    "        raise RuntimeError(f'❌ Could not import {pkg}: {e}')\n",
    "\n",
    "# ── Download DreamBooth LoRA training script ───────────────\n",
    "SCRIPT_URL = (\n",
    "    'https://raw.githubusercontent.com/huggingface/diffusers/v0.27.2'\n",
    "    '/examples/dreambooth/train_dreambooth_lora.py'\n",
    ")\n",
    "if not os.path.exists('/content/train_dreambooth_lora.py'):\n",
    "    subprocess.run(['wget', '-q', '-O', '/content/train_dreambooth_lora.py', SCRIPT_URL], check=True)\n",
    "    print('✅ train_dreambooth_lora.py downloaded')\n",
    "else:\n",
    "    print('✅ train_dreambooth_lora.py already present')\n",
    "\n",
    "# ── Configure accelerate (non-interactive) ─────────────────\n",
    "ACCELERATE_CONFIG = '''\n",
    "compute_environment: LOCAL_MACHINE\n",
    "debug: false\n",
    "distributed_type: 'NO'\n",
    "downcast_bf16: 'no'\n",
    "gpu_ids: '0'\n",
    "machine_rank: 0\n",
    "main_training_function: main\n",
    "mixed_precision: fp16\n",
    "num_machines: 1\n",
    "num_processes: 1\n",
    "rdzv_backend: static\n",
    "same_network: true\n",
    "tpu_env: []\n",
    "tpu_use_cluster: false\n",
    "tpu_use_sudo: false\n",
    "use_cpu: false\n",
    "'''.strip()\n",
    "\n",
    "cfg_dir = os.path.expanduser('~/.cache/huggingface/accelerate')\n",
    "os.makedirs(cfg_dir, exist_ok=True)\n",
    "with open(f'{cfg_dir}/default_config.yaml', 'w') as f:\n",
    "    f.write(ACCELERATE_CONFIG)\n",
    "print('✅ accelerate configured (fp16, single GPU)')\n",
    "print('\\n🏁 Cell 1 complete.')\n"
   ]
