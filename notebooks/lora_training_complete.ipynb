    "# ============================================================\n",
    "# CELL 0 — Environment Check & Drive Mount\n",
    "# ============================================================\n",
    "import torch, os, subprocess, sys\n",
    "\n",
    "print('=' * 55)\n",
    "print('TOONIFY LoRA Training — Environment Check')\n",
    "print('=' * 55)\n",
