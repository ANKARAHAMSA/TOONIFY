    "    raise RuntimeError(\n",
    "        '❌ No GPU detected!\\n'\n",
    "        'Go to: Runtime > Change runtime type > Hardware accelerator > T4 GPU\\n'\n",
    "        'Then reconnect and re-run this cell.'\n",
    "    )\n",
    "\n",
    "gpu = torch.cuda.get_device_properties(0)\n",
    "vram_gb = gpu.total_memory / 1e9\n",
    "print(f'✅ GPU: {gpu.name}')\n",
    "print(f'✅ VRAM: {vram_gb:.1f} GB')\n",
    "\n",
    "if vram_gb < 12:\n",
    "    print('⚠️  Low VRAM (<12GB) — will enable gradient checkpointing + 8-bit Adam')\n",
