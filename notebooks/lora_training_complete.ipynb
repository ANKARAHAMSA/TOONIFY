    "# ============================================================\n",
    "# CELL 2 — Download Base Model (resume-safe Drive cache)\n",
    "# ============================================================\n",
    "import os\n",
    "from huggingface_hub import snapshot_download\n",
    "\n",
    "BASE_MODEL_ID = 'nitrosocke/mo-di-diffusion'\n",
    "\n",
    "# Check if already cached in Drive\n",
    "required_files = ['unet/config.json', 'vae/config.json', 'tokenizer/vocab.json']\n",
    "already_cached = all(os.path.exists(f'{MODEL_DIR}/{f}') for f in required_files)\n",
    "\n",
    "if already_cached:\n",
    "    print(f'✅ Base model already in Drive at {MODEL_DIR} — skipping download')\n",
    "else:\n",
    "    print(f'Downloading {BASE_MODEL_ID} → {MODEL_DIR}')\n",
    "    print('This is ~4GB and takes 5–10 minutes on Colab...')\n",
    "    snapshot_download(\n",
    "        repo_id=BASE_MODEL_ID,\n",
    "        local_dir=MODEL_DIR,\n",
    "        ignore_patterns=['*.msgpack', '*.h5', 'flax_model*'],  # skip flax weights\n",
    "    )\n",
    "    print(f'✅ Model saved to Drive: {MODEL_DIR}')\n",
    "\n",
    "# Quick sanity check\n",
    "for f in required_files:\n",
    "    path = f'{MODEL_DIR}/{f}'\n",
    "    if not os.path.exists(path):\n",
    "        raise FileNotFoundError(f'❌ Expected file missing: {path}')\n",
    "print('✅ Model integrity check passed')\n",
    "print('\\n🏁 Cell 2 complete.')\n"
   ]
  },
