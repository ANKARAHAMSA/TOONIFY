   "source": [
    "# ============================================================\n",
    "# CELL 5 — Train LoRA (DreamBooth, resume-safe)\n",
    "# ============================================================\n",
    "import os, subprocess, sys, torch\n",
    "\n",
    "# ── Config ─────────────────────────────────────────────────\n",
    "INSTANCE_PROMPT    = 'a photo of a person in arcane_toonify style'\n",
    "CLASS_PROMPT       = 'a photo of a person'   # for prior preservation\n",
    "MAX_TRAIN_STEPS    = 1500\n",
    "LEARNING_RATE      = '1e-4'\n",
    "LR_SCHEDULER       = 'cosine'\n",
    "RANK               = 16   # LoRA rank (higher = more expressive, more VRAM)\n",
    "TRAIN_BATCH_SIZE   = 1\n",
    "GRADIENT_ACCUM     = 4    # effective batch = 4\n",
    "SAVE_STEPS         = 300\n",
    "RESOLUTION         = 512\n",
    "\n",
    "# Auto-enable VRAM guards\n",
    "vram_gb = torch.cuda.get_device_properties(0).total_memory / 1e9\n",
    "USE_GRAD_CKPT  = '--gradient_checkpointing' if vram_gb < 14 else ''\n",
    "USE_8BIT_ADAM  = '--use_8bit_adam'          if vram_gb < 14 else ''\n",
    "USE_XFORMERS   = '--enable_xformers_memory_efficient_attention'\n",
    "\n",
    "# Check for existing checkpoint to resume\n",
    "checkpoint_dirs = sorted([\n",
    "    d for d in os.listdir(LORA_DIR)\n",
    "    if d.startswith('checkpoint-') and os.path.isdir(f'{LORA_DIR}/{d}')\n",
    "])\n",
    "RESUME_FLAG = f'--resume_from_checkpoint {LORA_DIR}/{checkpoint_dirs[-1]}' if checkpoint_dirs else ''\n",
    "\n",
    "if RESUME_FLAG:\n",
    "    print(f'⏩  Resuming from checkpoint: {checkpoint_dirs[-1]}')\n",
    "else:\n",
    "    print('🚀 Starting fresh training run')\n",
    "\n",
    "print(f'   Steps: {MAX_TRAIN_STEPS}  |  LR: {LEARNING_RATE}  |  Rank: {RANK}  |  VRAM: {vram_gb:.1f}GB')\n",
    "print(f'   Gradient checkpointing: {bool(USE_GRAD_CKPT)}  |  8-bit Adam: {bool(USE_8BIT_ADAM)}')\n",
    "print('   ⏱  Estimated time: 45–90 min on T4\\n')\n",
    "\n",
    "cmd = [\n",
    "    'accelerate', 'launch', '/content/train_dreambooth_lora.py',\n",
    "    f'--pretrained_model_name_or_path={MODEL_DIR}',\n",
    "    f'--instance_data_dir={IMAGES_DIR}',\n",
    "    f'--output_dir={LORA_DIR}',\n",
    "    f'--instance_prompt={INSTANCE_PROMPT}',\n",
    "    f'--resolution={RESOLUTION}',\n",
    "    f'--train_batch_size={TRAIN_BATCH_SIZE}',\n",
    "    f'--gradient_accumulation_steps={GRADIENT_ACCUM}',\n",
    "    f'--max_train_steps={MAX_TRAIN_STEPS}',\n",
    "    f'--learning_rate={LEARNING_RATE}',\n",
    "    f'--lr_scheduler={LR_SCHEDULER}',\n",
    "    f'--lr_warmup_steps=100',\n",
    "    f'--rank={RANK}',\n",
    "    f'--checkpointing_steps={SAVE_STEPS}',\n",
    "    '--mixed_precision=fp16',\n",
    "    '--dataloader_num_workers=0',\n",
    "]\n",
    "\n",
    "if USE_GRAD_CKPT:\n",
    "    cmd.append(USE_GRAD_CKPT)\n",
    "if USE_8BIT_ADAM:\n",
    "    cmd.append(USE_8BIT_ADAM)\n",
    "if USE_XFORMERS:\n",
