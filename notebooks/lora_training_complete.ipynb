    "# ============================================================\n",
    "# CELL 3 — Generate 30 Real Arcane-Style Training Images\n",
    "#           Uses the loaded SD pipeline to generate actual art\n",
    "# ============================================================\n",
    "import torch\n",
    "from diffusers import StableDiffusionPipeline\n",
    "from PIL import Image\n",
    "import json, os\n",
    "\n",
    "N_IMAGES = 30\n",
    "TRIGGER_WORD = 'arcane_toonify style'\n",
    "\n",
    "# ── Check if images already exist ─────────────────────────\n",
    "existing = [f for f in os.listdir(IMAGES_DIR) if f.endswith('.png')]\n",
    "if len(existing) >= N_IMAGES:\n",
    "    print(f'✅ {len(existing)} training images already in Drive — skipping generation')\n",
    "    print('   Delete them from Drive if you want to regenerate.')\n",
    "else:\n",
    "    print(f'Generating {N_IMAGES} Arcane-style training images...')\n",
    "    print('⏱  ~25–35 sec per image on T4 → ~15 min total')\n",
    "\n",
    "    # ── Load pipeline ─────────────────────────────────────\n",
    "    if 'pipe' not in dir() or pipe is None:\n",
    "        print('Loading SD pipeline (this takes ~1 min)...')\n",
    "        pipe = StableDiffusionPipeline.from_pretrained(\n",
    "            MODEL_DIR,\n",
    "            torch_dtype=torch.float16,\n",
    "            safety_checker=None,\n",
    "        ).to('cuda')\n",
    "        pipe.enable_attention_slicing()\n",
    "\n",
    "    TRAINING_PROMPTS = [\n",
    "        f'{TRIGGER_WORD}, portrait of a young woman, painterly oil texture, blue teal atmosphere, dramatic lighting, masterpiece',\n",
    "        f'{TRIGGER_WORD}, close up face of a man, dark background, glowing eyes, high detail, masterpiece',\n",
    "        f'{TRIGGER_WORD}, character portrait, vibrant colors, moody lighting, bokeh background, masterpiece',\n",
    "        f'{TRIGGER_WORD}, portrait, violet and teal tones, sharp features, cinematic, masterpiece',\n",
    "        f'{TRIGGER_WORD}, female character, ambient glow, dark fantasy atmosphere, masterpiece',\n",
    "        f'{TRIGGER_WORD}, male face, painterly brush strokes, blue haze, detailed, masterpiece',\n",
    "        f'{TRIGGER_WORD}, warrior portrait, glowing tattoos, dark medieval city, masterpiece',\n",
    "        f'{TRIGGER_WORD}, young woman, braided hair, teal lighting, expressive eyes, masterpiece',\n",
    "        f'{TRIGGER_WORD}, steampunk character, goggles, dark metallic tones, dramatic, masterpiece',\n",
    "        f'{TRIGGER_WORD}, close-up portrait, oil painting texture, purple and gold color grade, masterpiece',\n",
    "        f'{TRIGGER_WORD}, hooded character, mysterious, glowing runes, blue fog, masterpiece',\n",
    "        f'{TRIGGER_WORD}, portrait, rough painted edges, vivid blues and oranges, masterpiece',\n",
    "        f'{TRIGGER_WORD}, scientist character, bright lab background, sharp face, masterpiece',\n",
    "        f'{TRIGGER_WORD}, portrait of an elder, wise eyes, deep shadows, teal accent, masterpiece',\n",
    "        f'{TRIGGER_WORD}, rebel character, grunge aesthetic, neon undercity lights, masterpiece',\n",
    "        f'{TRIGGER_WORD}, fantasy portrait, magic swirling around, deep color saturation, masterpiece',\n",
    "        f'{TRIGGER_WORD}, profile view portrait, architectural bokeh, golden hour light, masterpiece',\n",
    "        f'{TRIGGER_WORD}, street fighter, intense gaze, blood and dust, dark, masterpiece',\n",
    "        f'{TRIGGER_WORD}, female warrior, silver armor, glowing blue runes, epic, masterpiece',\n",
    "        f'{TRIGGER_WORD}, child portrait, innocent expression, colorful undercity, masterpiece',\n",
    "        f'{TRIGGER_WORD}, portrait, front lighting, intricate face details, painterly, masterpiece',\n",
    "        f'{TRIGGER_WORD}, noble character, formal attire, candlelight, moody, masterpiece',\n",
    "        f'{TRIGGER_WORD}, mercenary, scar on cheek, desert dust, hard shadows, masterpiece',\n",
    "        f'{TRIGGER_WORD}, mage character, glowing purple orb, dark robes, masterpiece',\n",
    "        f'{TRIGGER_WORD}, cybernetic face, glowing circuits, oil painting effect, masterpiece',\n",
    "        f'{TRIGGER_WORD}, thief, sneaking expression, urban backdrop, low light, masterpiece',\n",
    "        f'{TRIGGER_WORD}, healer character, warm golden glow, gentle expression, masterpiece',\n",
    "        f'{TRIGGER_WORD}, sniper, focused eyes, rooftop, evening light, masterpiece',\n",
    "        f'{TRIGGER_WORD}, two characters, symmetrical composition, blue tones, masterpiece',\n",
    "        f'{TRIGGER_WORD}, villain portrait, menacing gaze, dark energy swirling, red accents, masterpiece',\n",
    "    ]\n",
    "\n",
    "    NEGATIVE = 'ugly, blurry, lowres, bad anatomy, watermark, jpeg artifacts, deformed, disfigured'\n",
    "    metadata = []\n",
    "\n",
    "    for i, prompt in enumerate(TRAINING_PROMPTS[:N_IMAGES], 1):\n",
    "        fname = f'arcane_{i:03d}.png'\n",
    "        fpath = f'{IMAGES_DIR}/{fname}'\n",
    "\n",
    "        if os.path.exists(fpath):\n",
    "            print(f'  ⏭  {fname} already exists — skipping')\n",
    "        else:\n",
    "            try:\n",
    "                result = pipe(\n",
    "                    prompt=prompt,\n",
    "                    negative_prompt=NEGATIVE,\n",
    "                    width=512, height=512,\n",
    "                    num_inference_steps=30,\n",
    "                    guidance_scale=7.5,\n",
    "                    generator=torch.Generator('cuda').manual_seed(i * 42),\n",
    "                ).images[0]\n",
    "                result.save(fpath)\n",
    "                print(f'  ✅ [{i:02d}/{N_IMAGES}] {fname} saved')\n",
    "            except torch.cuda.OutOfMemoryError:\n",
    "                torch.cuda.empty_cache()\n",
    "                print(f'  ⚠️  VRAM OOM on image {i} — enabling attention slicing and retrying...')\n",
    "                pipe.enable_attention_slicing(1)\n",
    "                result = pipe(\n",
    "                    prompt=prompt,\n",
    "                    negative_prompt=NEGATIVE,\n",
    "                    width=512, height=512,\n",
    "                    num_inference_steps=25,\n",
    "                    guidance_scale=7.0,\n",
    "                    generator=torch.Generator('cuda').manual_seed(i * 42),\n",
    "                ).images[0]\n",
    "                result.save(fpath)\n",
    "                print(f'  ✅ [{i:02d}/{N_IMAGES}] {fname} saved (OOM fallback)')\n",
    "\n",
    "        metadata.append({'file_name': fname, 'text': prompt})\n",
    "\n",
    "    # Write metadata.jsonl\n",
    "    meta_path = f'{IMAGES_DIR}/metadata.jsonl'\n",
    "    with open(meta_path, 'w') as f:\n",
    "        for entry in metadata:\n",
    "            f.write(json.dumps(entry) + '\\n')\n",
    "    print(f'\\n✅ metadata.jsonl written ({N_IMAGES} entries)')\n",
    "\n",
    "    # Free the generation pipe from VRAM before training\n",
    "    del pipe\n",
    "    torch.cuda.empty_cache()\n",
    "    print('✅ Generation pipeline removed from VRAM')\n",
    "\n",
    "print(f'\\n📁 Training images ready: {IMAGES_DIR}')\n",
    "print('\\n🏁 Cell 3 complete.')\n"
   ]
  },
