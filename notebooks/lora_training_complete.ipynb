    "print(f'✅ CUDA: {torch.version.cuda}')\n",
    "\n",
    "# ── Mount Google Drive ─────────────────────────────────────\n",
    "print('\\nMounting Google Drive...')\n",
    "from google.colab import drive\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "DRIVE_ROOT = '/content/drive/MyDrive/toonify'\n",
