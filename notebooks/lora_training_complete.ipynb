    "IMAGES_DIR = f'{DRIVE_ROOT}/training_images/arcane'\n",
    "LORA_DIR   = f'{DRIVE_ROOT}/lora_output/arcane'\n",
    "\n",
    "for d in [MODEL_DIR, IMAGES_DIR, LORA_DIR]:\n",
    "    os.makedirs(d, exist_ok=True)\n",
    "\n",
    "print(f'✅ Drive mounted — root: {DRIVE_ROOT}')\n",
    "print('\\n🏁 Cell 0 complete — ready to install dependencies.')\n"
   ]
